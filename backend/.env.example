# =============================================
# CodeChronicle Backend — Environment Variables
# =============================================
# Copy this file to `.env` and fill in the values.
# These are used during `npx serverless deploy`.

# JWT Secret — CHANGE THIS for production!
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-in-production-use-a-random-64-byte-hex-string

# Brevo (formerly Sendinblue) — Transactional Email API Key
# Get yours at: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your-brevo-api-key-here

# Sender email — must be verified in your Brevo account
BREVO_SENDER_EMAIL=noreply@codechronicle.dev
